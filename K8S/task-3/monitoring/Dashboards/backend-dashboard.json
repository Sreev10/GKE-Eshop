{
    "title": "Backend Dashboard",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "5s",
    "panels": [
        {
            "type": "timeseries",
            "title": "CPU usage",
            "targets": [
                {
                   "expr": "rate(container_cpu_usage_seconds_total{prod=~\"backend.*\"}[5m])"
                }
            ]
        },
        {
            "type": "timeseries",
            "title": "Memory usage",
            "targets": [
                {
                    "expr": "container_memory_working_set_bytes{prod=~\"backend.*\"}"
                }
            ]
        },
        { 
            "type": "stat",
            "title": "Backend Replicas",
            "targets": [
                {
                    "expr": "kube_deployment_status_replicas{deployment=~\"backend.*\"}"
                }
            ]
        }
    ]

}