{
  "title": "Frontend Dashboard",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "panels": [
    {
      "type": "timeseries",
      "title": "CPU Usage",
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{pod=~\"frontend.*\"}[5m])"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Memory Usage",
      "targets": [
        {
          "expr": "container_memory_usage_bytes{pod=~\"frontend.*\"}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Frontend Replicas",
      "targets": [
        {
          "expr": "kube_deployment_status_replicas{deployment=\"frontend\"}"
        }
      ]
    }
  ]
}